@@ -72,6 +72,31 @@ from utils import base_url_host_matches, env_var_enabled
 
 logger = logging.getLogger(__name__)
 
+_TOOL_NARRATION_PATTERN = re.compile(
+    r"\b(?:I will|I'll|Let me)\s+(?:run|call|invoke|use)\s+"
+    r"(?P<tool_name>"
+    r"get_btc_price|get_node_diagnostic|get_morning_briefing|"
+    r"get_btc_forecast|get_capability_assessment|search_knowledge_vault|"
+    r"create_task|suggest_backlog_issue|vote_backlog_issue"
+    r")\b",
+    re.IGNORECASE,
+)
+
+
+def _detect_narrated_tool_retry(text: Any, valid_tool_names: set[str]) -> Optional[str]:
+    """Return the narrated tool name when visible text names a valid tool."""
+    if not isinstance(text, str) or not text.strip() or not valid_tool_names:
+        return None
+
+    match = _TOOL_NARRATION_PATTERN.search(text)
+    if not match:
+        return None
+
+    tool_name = match.group("tool_name")
+    if tool_name not in valid_tool_names:
+        return None
+    return tool_name
+
 
 def _ollama_context_limit_error(agent: Any, request_tokens: int) -> Optional[str]:
     """Return a user-facing error when Ollama is loaded with too little context."""
